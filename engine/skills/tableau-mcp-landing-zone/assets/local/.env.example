# Copy to .env (in this folder) and fill in. Used by docker-compose.yml in this folder.
# NEVER commit a real .env.

# --- Official Tableau MCP image -------------------------------------------------------
# Pin to a digest in real use, e.g. ghcr.io/tableau/tableau-mcp@sha256:<digest>
TABLEAU_MCP_IMAGE=ghcr.io/tableau/tableau-mcp:latest

# --- Auth sidecar image (published; pin by digest in real use) ------------------------
SIDECAR_IMAGE=ghcr.io/yarbrdab000/tableau-fabric-ai-bridge-sidecar:latest

# --- Tableau site + Connected App (Direct Trust) --------------------------------------
TABLEAU_SERVER=https://your-pod.online.tableau.com
TABLEAU_SITE=your-site-content-url
TABLEAU_CONNECTED_APP_CLIENT_ID=
TABLEAU_CONNECTED_APP_SECRET_ID=
TABLEAU_CONNECTED_APP_SECRET_VALUE=
# Tableau username the service account acts as for non-passthrough calls.
TABLEAU_SERVICE_ACCOUNT_USERNAME=svc-mcp@your-org.com

# --- Sidecar caller auth --------------------------------------------------------------
SIDECAR_API_KEY=change-me-to-a-long-random-string

# --- Identity mode --------------------------------------------------------------------
# service_account (default) or passthrough (Entra -> Tableau per-user RLS).
IDENTITY_MODE=service_account
# Passthrough also needs ENABLE_PASSTHROUGH_AUTH=true + TRUST_EASY_AUTH=true:
ENABLE_PASSTHROUGH_AUTH=false
TRUST_EASY_AUTH=false
UPN_MAPPING_MODE=direct
UPN_DOMAIN_FROM=
UPN_DOMAIN_TO=
ENTRA_TENANT_ID=

DEFAULT_LOG_LEVEL=info
